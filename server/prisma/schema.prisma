generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  memberships   GroupMember[]
  paidExpenses  Expense[]      @relation("PaidBy")
  expenseSplits ExpenseSplit[]
  sentSettlements Settlement[] @relation("PaidBy")
  receivedSettlements Settlement[] @relation("PaidTo")
}

model Group {
  id          String        @id @default(uuid())
  name        String
  createdAt   DateTime      @default(now())
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  group    Group     @relation(fields: [groupId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARE
}

model Expense {
  id               String         @id @default(uuid())
  groupId          String
  paidById         String
  amount           Float // Amount in INR
  originalAmount   Float?
  originalCurrency String?        @default("INR")
  exchangeRate     Float?         @default(1.0)
  description      String
  date             DateTime
  splitType        SplitType
  notes            String?
  createdAt        DateTime       @default(now())
  group            Group          @relation(fields: [groupId], references: [id])
  paidBy           User           @relation("PaidBy", fields: [paidById], references: [id])
  splits           ExpenseSplit[]
}

model ExpenseSplit {
  id         String  @id @default(uuid())
  expenseId  String
  userId     String
  owedAmount Float
  shareValue Float? // Can be percentage or share units
  expense    Expense @relation(fields: [expenseId], references: [id])
  user       User    @relation(fields: [userId], references: [id])
}

model Settlement {
  id        String   @id @default(uuid())
  groupId   String
  paidById  String
  paidToId  String
  amount    Float
  date      DateTime
  group     Group    @relation(fields: [groupId], references: [id])
  paidBy    User     @relation("PaidBy", fields: [paidById], references: [id])
  paidTo    User     @relation("PaidTo", fields: [paidToId], references: [id])
}

enum ImportStatus {
  DRAFT
  COMPLETED
  FAILED
}

model ImportLog {
  id        String          @id @default(uuid())
  fileName  String
  status    ImportStatus    @default(DRAFT)
  createdAt DateTime        @default(now())
  anomalies ImportAnomaly[]
}

model ImportAnomaly {
  id          String    @id @default(uuid())
  importLogId String
  rowNumber   Int
  rowData     String // JSON string of the original row
  anomalyType String
  description String
  actionTaken String // e.g., "Skipped", "Normalized", "Adjusted"
  importLog   ImportLog @relation(fields: [importLogId], references: [id])
}
